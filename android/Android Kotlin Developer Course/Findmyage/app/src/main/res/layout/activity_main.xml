<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".MainActivity">
    <EditText
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:ems="10"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" android:id="@+id/txtYearOfBirth" android:layout_marginTop="64dp"
            app:layout_constraintTop_toTopOf="parent" android:hint="enter your DOB"/>
    <TextView
            android:text="Your age shows here"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/colorAccent"
            android:id="@+id/tvShowAge" app:layout_constraintStart_toStartOf="parent" android:layout_marginStart="8dp"
            app:layout_constraintEnd_toEndOf="parent" android:layout_marginEnd="8dp" android:layout_marginTop="80dp"
            app:layout_constraintTop_toBottomOf="@+id/txtYearOfBirth" android:textSize="19sp" android:hint="enter your DOB"/>
    <Button
            android:text="Get My Age"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/colorAccent"
            android:id="@+id/buFindAge" app:layout_constraintEnd_toEndOf="parent" android:layout_marginEnd="8dp"
            app:layout_constraintStart_toStartOf="parent" android:layout_marginStart="8dp"
            android:layout_marginTop="56dp" app:layout_constraintTop_toBottomOf="@+id/tvShowAge"
            app:layout_constraintHorizontal_bias="0.817" android:onClick="buFindAgeEvent"/>
</android.support.constraint.ConstraintLayout>